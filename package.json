{
  "name": "playwright-runner",
  "version": "1.3.0",
  "description": "Playwright helper tools",
  "license": "ISC",
  "author": "Denis Shelest <axules@mail.ru>",
  "scripts": {
    "test": "jest",
    "example": "npx playwright test",
    "report": "npx playwright show-report",
    "build": "babel --delete-dir-on-start -d dist src --ignore **/*.test.js"
  },
  "main": "./dist/runner.js",
  "exports": {
    ".": "./dist/runner.js",
    "./runner": "./dist/runner.js",
    "./tools/*": "./dist/tools/*.js"
  },
  "files": [
    "dist",
    "src",
    "examples",
    "AGENTS.md",
    "README.md"
  ],
  "devDependencies": {
    "@babel/cli": "8.0.1",
    "@babel/core": "8.0.1",
    "@babel/preset-env": "8.0.2",
    "@babel/eslint-parser": "8.0.1",
    "@playwright/test": "1.61.1",
    "cross-env": "10.1.0",
    "eslint": "10.5.0",
    "@stylistic/eslint-plugin": "6.0.0-beta.5",
    "globals": "17.7.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-import-newlines": "2.0.0",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-presets": "github:axules/eslint-presets#v1.0.7",
    "jest": "30.4.2",
    "playwright": "1.61.1"
  },
  "peerDependencies": {
    "@playwright/test": "1.x - x",
    "playwright": "1.x - x"
  },
  "dependencies": {
    "lodash.isstring": "4.0.1",
    "jpeg-js": "0.4.4",
    "pixelmatch": "7.2.0"
  },
  "overrides": {
    "eslint": "10.5.0"
  }
}
